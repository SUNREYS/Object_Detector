# =============================================================================
# .gitignore for KAIST Pedestrian Detection Thesis Project
# =============================================================================

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
*.egg

# --- Datasets (too large for git) ---
datasets/

# --- Model weights ---
*.pt
*.pth
*.onnx
PID/

# --- Training runs (logs, checkpoints, batch images) ---
#OD/runs/

# --- Evaluation output (regenerated by evaluate.py) ---
#OD/eval_results/

# --- Generated plots (regenerated by plot_results.py) ---
#OD/plots/
#datasets/kaist_processed/plots/

# --- OS / IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# --- Docker ---
.docker/

# --- Misc ---
*.log
*.tmp
